{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "department": { "type": "string" },
        "role": { "type": "string", "enum": ["applicant", "admin"] },
        "completedTest": { "type": "boolean" },
        "assignedTeamId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Question": {
      "title": "Question",
      "description": "MCQ test question",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "weights": {
                "type": "object",
                "properties": {
                  "leadership": { "type": "number" },
                  "organization": { "type": "number" },
                  "communication": { "type": "number" },
                  "creativity": { "type": "number" },
                  "analysis": { "type": "number" },
                  "execution": { "type": "number" }
                }
              }
            }
          }
        },
        "active": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["text", "options", "active"]
    },
    "Response": {
      "title": "Response",
      "description": "Individual answer to a question",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionId": { "type": "string" },
        "selectedOptionIndex": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "questionId", "selectedOptionIndex"]
    },
    "Score": {
      "title": "Score",
      "description": "Calculated profile for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "leadership": { "type": "number" },
        "organization": { "type": "number" },
        "communication": { "type": "number" },
        "creativity": { "type": "number" },
        "analysis": { "type": "number" },
        "execution": { "type": "number" },
        "primaryTrait": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    },
    "Team": {
      "title": "Team",
      "description": "A balanced team",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "minSize": { "type": "number" },
        "maxSize": { "type": "number" },
        "memberCount": { "type": "number" }
      },
      "required": ["name", "minSize", "maxSize"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Mapping of user to team",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "teamId": { "type": "string" },
        "assignedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "teamId"]
    },
    "Session": {
      "title": "Session",
      "description": "Live or recorded educational session",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "titleAr": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "link": { "type": "string" },
        "active": { "type": "boolean" },
        "hasQuiz": { "type": "boolean" }
      },
      "required": ["title", "date", "endTime", "active"]
    },
    "SessionQuestion": {
      "title": "SessionQuestion",
      "description": "Quiz question for a specific session",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "text": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctOptionIndex": { "type": "number" }
      },
      "required": ["sessionId", "text", "options", "correctOptionIndex"]
    },
    "SessionQuizResult": {
      "title": "SessionQuizResult",
      "description": "User results for a session quiz",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" }
      },
      "required": ["sessionId", "userId", "score"]
    },
    "SessionFeedback": {
      "title": "SessionFeedback",
      "description": "User feedback and rating for a session",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "overallRating": { "type": "number" },
        "topicRating": { "type": "number" },
        "instructorRating": { "type": "number" },
        "benefitRating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sessionId", "userId", "overallRating", "topicRating", "instructorRating", "benefitRating", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/questions/{questionId}": { "schema": "Question", "description": "Test questions" },
    "/responses/{responseId}": { "schema": "Response", "description": "User test responses" },
    "/scores/{userId}": { "schema": "Score", "description": "Calculated user profiles" },
    "/teams/{teamId}": { "schema": "Team", "description": "Team definitions" },
    "/assignments/{assignmentId}": { "schema": "Assignment", "description": "Team assignments" },
    "/sessions/{sessionId}": { "schema": "Session", "description": "Educational sessions" },
    "/sessionQuestions/{questionId}": { "schema": "SessionQuestion", "description": "Questions for session quizzes" },
    "/sessionQuizResults/{resultId}": { "schema": "SessionQuizResult", "description": "User quiz attempts" },
    "/sessionFeedbacks/{feedbackId}": { "schema": "SessionFeedback", "description": "Session ratings and feedback" }
  }
}
